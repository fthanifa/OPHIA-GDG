# ── OPHIA HACKATHON ENV TEMPLATE ─────────────────────────────────────────────
# Copy this file, rename the copy to .env, and fill in the real values
# NEVER commit the actual .env file

# Google Cloud Platform
GCP_PROJECT_ID="your-gcp-project-id-here"
GCP_LOCATION="asia-southeast1"

# Firebase / Firestore (Fitri's DB)
FIREBASE_CREDENTIALS_PATH="./ophia-data/credentials/firebase-adminsdk.json"

# Google Workspace Automation (Fitri's Trigger)
WORKSPACE_CREDENTIALS_PATH="./ophia-data/credentials/workspace-credentials.json"
SENDER_EMAIL="your-gmail@gmail.com"

# API Server (Razin's server)
HOST="0.0.0.0"
PORT=8000